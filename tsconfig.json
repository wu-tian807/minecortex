{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.ts",
    "subscriptions/**/*.ts",
    "tools/**/*.ts",
    "slots/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "brains/*/src/**"]
}
